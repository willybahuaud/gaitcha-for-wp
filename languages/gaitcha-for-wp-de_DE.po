msgstr "Basis"

msgid "Advanced"
msgstr "Erweitert"

msgid "Style"
msgstr "Stil"

msgid "Classes"
msgstr "Klassen"

msgid "Breakpoints"
msgstr "Haltepunkte"

msgid "Spam Protection"
msgstr "Spam-Schutz"

msgid "captcha spam gaitcha"
msgstr "captcha spam gaitcha"

msgid "Gaitcha form-tag generator"

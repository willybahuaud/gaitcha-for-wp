#. Plugin Name of the plugin
msgid "Gaitcha for WordPress"
msgstr "Gaitcha para WordPress"

#. Description of the plugin
msgid "Self-hosted behavioral captcha — no external dependency."
msgstr "Captcha conductual autoalojado — sin dependencia externa."

msgid "Yes, I'm a real person"
msgstr "Sí, soy una persona real"

msgid "Verification failed. Please try again."
msgstr "La verificación ha fallado. Por favor, inténtelo de nuevo."

msgid "Gaitcha"
msgstr "Gaitcha"

msgid "Adds a Gaitcha behavioral captcha checkbox to your form."
msgstr "Añade una casilla captcha conductual Gaitcha a tu formulario."

msgid "Gaitcha captcha will appear here"
msgstr "El captcha Gaitcha aparecerá aquí"

msgid "captcha spam gaitcha behavioral"
msgstr "captcha spam gaitcha conductual"

msgid "Basic"
msgstr "Básico"

msgid "Advanced"
msgstr "Avanzado"

msgid "Style"
msgstr "Estilo"

msgid "Classes"
msgstr "Clases"

msgid "Breakpoints"
msgstr "Puntos de ruptura"

msgid "Spam Protection"
msgstr "Protección antispam"

msgid "captcha spam gaitcha"
msgstr "captcha spam gaitcha"

msgid "Gaitcha form-tag generator"
msgstr "Generador de etiqueta de formulario Gaitcha"

msgid "Generates a form-tag for the Gaitcha captcha checkbox."
msgstr "Genera una etiqueta de formulario para la casilla captcha Gaitcha."

msgid "Unable to rename the plugin directory."
msgstr "No se ha podido renombrar el directorio del plugin."

msgid "No release notes available."
msgstr "No hay notas de versión disponibles."
